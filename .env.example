# Copy to .env and fill in. .env is gitignored.

# Where sample clips + extracted data live.
# Local default:  ~/EI/egobench/data
# AWS default:    /mnt/data/egobench   (EBS / instance store, NOT the repo)
DATA_ROOT=./data

# Where predictions (.npz) and plots are written.
OUTPUT_ROOT=./outputs

# Compute device: "cpu", "cuda", or "auto"
DEVICE=auto

# HuggingFace token with Stera-10M access granted.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Disk budget guard (GB) for scripts/fetch_samples.py, refuses to exceed.
# Local box has ~38GB free; keep the ceiling conservative.
FETCH_DISK_BUDGET_GB=25
